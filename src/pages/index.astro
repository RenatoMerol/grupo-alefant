<!-- SERVICES -->
<section class="services service-atelier" id="servicios">
  <div class="container">
    <div class="section-head split-head reveal">
      <div>
        <p class="section-label">Servicios</p>
        <h2>Una firma para todo el recorrido</h2>
      </div>
      <p>El trabajo se organiza como un sistema: diagnostico, concepto, presupuesto, ejecucion y entrega. Cada servicio vive conectado al resultado final.</p>
    </div>
    <div class="service-showcase">
      <div class="service-visual reveal">
        <img id="serviceImage" src="images/construction.jpg" alt="Obra residencial en proceso" loading="lazy">
        <svg class="service-drawing" viewBox="0 0 420 320" aria-hidden="true">
          <path d="M32 262h356M62 262V78h238v184M104 262V122h154v140M62 148h238M62 206h238M104 176h154"/>
          <path d="M300 78l64 58v126M300 78v58h64"/>
        </svg>
        <div class="visual-caption" id="serviceCaption">Obra nueva con planeacion, estructura y acabados coordinados.</div>
      </div>
      <div class="service-list reveal">
        <article class="service-row active" tabindex="0" data-image="images/construction.jpg" data-caption="Obra nueva con planeacion, estructura y acabados coordinados.">
          <span>01</span>
          <div>
            <h3>Construccion nueva</h3>
            <p>Residencias, departamentos y espacios comerciales desarrollados desde cimentacion hasta entrega.</p>
          </div>
        </article>
        <article class="service-row" tabindex="0" data-image="images/remodel.jpg" data-caption="Remodelaciones que actualizan el espacio sin perder control de obra ni presupuesto.">
          <span>02</span>
          <div>
            <h3>Remodelacion</h3>
            <p>Cocinas, banos, fachadas, interiores y redistribuciones con ejecucion limpia y precisa.</p>
          </div>
        </article>
        <article class="service-row" tabindex="0" data-image="images/pool.jpg" data-caption="Mejoras exteriores pensadas como extensiones naturales de la vivienda.">
          <span>03</span>
          <div>
            <h3>Mejoras del hogar</h3>
            <p>Albercas, terrazas, ampliaciones y detalles que elevan la vida diaria de la casa.</p>
          </div>
        </article>
        <article class="service-row" tabindex="0" data-image="images/architecture.jpg" data-caption="Direccion arquitectonica para convertir ideas en planos, materiales y decisiones de obra.">
          <span>04</span>
          <div>
            <h3>Diseno arquitectonico</h3>
            <p>Planos, renders, seleccion de materiales y direccion para que el proyecto avance con claridad.</p>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<!-- PORTFOLIO -->
<section class="portfolio portfolio-editorial" id="proyectos">
  <div class="container">
    <div class="portfolio-header reveal">
      <div>
        <p class="section-label">Portafolio</p>
        <h2>Capacidades vistas como proyectos</h2>
      </div>
      <p class="portfolio-note">Galeria de obra, remodelacion, interiores y exteriorismo.</p>
    </div>
    <div class="project-layout">
      <article class="project-feature reveal">
        <img src="images/hero.jpg" alt="Residencia moderna con fachada limpia" loading="lazy">
        <div class="project-copy">
          <span>Residencial integral</span>
          <h3>De la estructura a la experiencia de habitar</h3>
          <p>Coordinamos estructura, acabados, exteriores e interiores para que la residencia funcione como un proyecto completo.</p>
        </div>
      </article>
      <div class="project-stack">
        <article class="project-card reveal stagger">
          <img src="images/kitchen.jpg" alt="Cocina residencial remodelada" loading="lazy">
          <div><span>Remodelacion</span><h3>Cocinas e interiores</h3></div>
        </article>
        <article class="project-card reveal stagger">
          <img src="images/pool.jpg" alt="Alberca residencial con area exterior" loading="lazy">
          <div><span>Exteriorismo</span><h3>Albercas y terrazas</h3></div>
        </article>
